# Database Connection (Matches docker-compose settings)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/campusiq?schema=public

# NextAuth Configurations
NEXTAUTH_SECRET=your-nextauth-secret-here-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Google OAuth Provider (Optional, login works with credentials provider too)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq API Configuration for Admissions counseling predictor
GROQ_API_KEY=
